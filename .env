# ESP32 Device Configuration
# Replace with your actual ESP32 IP address or hostname

# For local network
VITE_ESP32_HOST=http://192.168.1.100
VITE_ESP32_PORT=80

# Alternative: if your ESP32 is on a different port
# VITE_ESP32_HOST=http://192.168.4.1
# VITE_ESP32_PORT=8080

# Development mode
VITE_MODE=development
